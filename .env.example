# PrediScore — variables d'environnement
# Ne jamais committer de vraies clés.

# --- Site public ---
# Utilisé pour les URLs SEO et le retour Google/Supabase après connexion.
NEXT_PUBLIC_SITE_URL=https://prediscore.io
NEXT_PUBLIC_CLARITY_ID=xengydmkc

# --- OpenAI ---
# SERVER ONLY. Utilisé pour la narration des analyses et le Coach IA.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- API-Football ---
# SERVER ONLY. La saison produit reste 2025/2026 ; si ton plan API ne couvre pas
# encore 2025, PrediScore bascule en fallback démo sans afficher de faux badge live.
API_FOOTBALL_KEY=
# API_FOOTBALL_HOST=https://v3.football.api-sports.io
# API_FOOTBALL_RAPID_HOST=

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Whop ---
# Les checkouts PrediScore sont considérés actifs uniquement quand les 3 IDs sont posés.
WHOP_API_KEY=
WHOP_WEBHOOK_SECRET=
WHOP_PLAN_ESSENTIEL=
WHOP_PLAN_PRO=
WHOP_PLAN_LIFETIME=

# --- Preview interne ---
# Permet de simuler l'analyse complète sans paiement sur un environnement privé.
# Ne pas activer en production publique.
# PREDISCORE_PREVIEW_UNLOCK=1
